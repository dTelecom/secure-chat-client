# Shared dMeet test environment — copy to .env.test and never commit.
# Same wallet/registry the dMeet test environment uses.

# Tenant Ed25519 wallet (base58 public key, == iss in chat tokens).
LK_API_KEY=

# Tenant Ed25519 wallet secret key (base58, 64 bytes Solana-style:
# 32-byte seed concatenated with 32-byte public key).
LK_API_SECRET=

# Solana program ID hosting the client registry.
CONTRACT_ADDRESS=

# Registry authority pubkey (PDA seed component).
REGISTRY_AUTHORITY=

# Solana RPC endpoint. Devnet by default.
SOLANA_HOST_HTTP=https://api.devnet.solana.com
